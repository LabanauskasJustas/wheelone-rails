<% cancel_path ||= visualization.persisted? ? [:account, visualization] : [:account, @team, :visualizations] %>

<%= form_with model: visualization,
      url: (visualization.persisted? ? [:account, visualization] : [:account, @team, :visualizations]),
      data: { controller: "visualization-preview" } do |form| %>
  <%= render "shared/limits/form", form: form, cancel_path: cancel_path do %>
    <%= render 'account/shared/forms/errors', form: form %>

    <div class="bg-white rounded-xl shadow-xl shadow-slate-200/50 overflow-hidden border border-slate-100">
      <div class="grid grid-cols-1 md:grid-cols-2 divide-x divide-slate-100">

        <%# ── Left: Ratlankis ────────────────────────────────── %>
        <div class="p-8 space-y-6">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-primary-container/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary-container">settings</span>
            </div>
            <h3 class="font-headline text-lg font-extrabold uppercase tracking-tight">Ratlankis</h3>
          </div>

          <%# Preview area %>
          <div class="aspect-square w-full bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200 overflow-hidden relative">
            <img data-visualization-preview-target="rimPreview"
                 class="w-full h-full object-cover hidden" />
            <div data-visualization-preview-target="rimPlaceholder"
                 class="absolute inset-0 flex flex-col items-center justify-center gap-3">
              <span class="material-symbols-outlined text-slate-300" style="font-size: 64px;">settings</span>
              <p class="text-xs text-slate-400 font-label uppercase tracking-widest">Pasirinkite ratlankį</p>
            </div>
          </div>

          <%# Selector %>
          <div class="space-y-2">
            <%= form.label :rim_id, "Pasirinkite ratlankį",
                  class: "block font-label text-[10px] uppercase tracking-widest font-bold text-slate-400" %>
            <%= form.select :rim_id,
                  @visualization.valid_rims.map { |rim|
                    [rim.label_string, rim.id, {
                      data: { photo_url: rim.photo.attached? ? rails_representation_url(rim.photo.variant(format: :jpeg)) : "" }
                    }]
                  },
                  { include_blank: "— pasirinkite —", selected: visualization.rim_id },
                  {
                    data: {
                      visualization_preview_target: "rimSelect",
                      action: "change->visualization-preview#rimChanged"
                    },
                    class: "w-full bg-white border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium text-slate-700 focus:ring-2 focus:ring-primary-container/20 focus:border-primary-container outline-none transition-all appearance-none cursor-pointer"
                  } %>
          </div>
        </div>

        <%# ── Right: Automobilis ──────────────────────────────── %>
        <div class="p-8 space-y-6">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-primary-container/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary-container">directions_car</span>
            </div>
            <h3 class="font-headline text-lg font-extrabold uppercase tracking-tight">Automobilis</h3>
          </div>

          <%# Preview area %>
          <div class="aspect-square w-full bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200 overflow-hidden relative">
            <img data-visualization-preview-target="carPreview"
                 class="w-full h-full object-cover hidden" />
            <div data-visualization-preview-target="carPlaceholder"
                 class="absolute inset-0 flex flex-col items-center justify-center gap-3">
              <span class="material-symbols-outlined text-slate-300" style="font-size: 64px;">directions_car</span>
              <p class="text-xs text-slate-400 font-label uppercase tracking-widest">Pasirinkite automobilį</p>
            </div>
          </div>

          <%# Selector %>
          <div class="space-y-2">
            <%= form.label :car_id, "Pasirinkite automobilį",
                  class: "block font-label text-[10px] uppercase tracking-widest font-bold text-slate-400" %>
            <%= form.select :car_id,
                  @visualization.valid_cars.map { |car|
                    [car.label_string, car.id, {
                      data: { photo_url: car.photo.attached? ? rails_representation_url(car.photo.variant(format: :jpeg)) : "" }
                    }]
                  },
                  { include_blank: "— pasirinkite —", selected: visualization.car_id },
                  {
                    data: {
                      visualization_preview_target: "carSelect",
                      action: "change->visualization-preview#carChanged"
                    },
                    class: "w-full bg-white border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium text-slate-700 focus:ring-2 focus:ring-primary-container/20 focus:border-primary-container outline-none transition-all appearance-none cursor-pointer"
                  } %>
          </div>
        </div>

      </div>

      <%# ── Footer ─────────────────────────────────────────────── %>
      <div class="px-8 py-6 bg-slate-50/80 border-t border-slate-100 flex items-center justify-between">
        <%= link_to t('global.buttons.cancel'), cancel_path,
              class: "text-sm font-bold text-slate-400 hover:text-slate-600 transition-colors uppercase tracking-widest font-headline" %>

        <button type="submit"
                class="inline-flex items-center gap-3 px-8 py-4 rounded-lg text-white font-headline font-bold text-sm tracking-tight shadow-xl shadow-blue-500/30 hover:shadow-2xl hover:-translate-y-1 active:scale-95 transition-all duration-300"
                style="background: linear-gradient(135deg, #0053da 0%, #346df5 100%)">
          <span class="material-symbols-outlined text-base">image</span>
          <%= form.object.persisted? ? t('.buttons.update') : t('.buttons.create') %>
        </button>
      </div>
    </div>

  <% end %>
<% end %>
