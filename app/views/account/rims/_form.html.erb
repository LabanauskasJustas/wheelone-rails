<% cancel_path ||= rim.persisted? ? [:account, rim] : [:account, @team, :rims] %>

<%= form_with model: rim, url: (rim.persisted? ? [:account, rim] : [:account, @team, :rims]) do |form| %>
  <%= render "shared/limits/form", form: form, cancel_path: cancel_path do %>
    <%= render 'account/shared/forms/errors', form: form %>

    <div class="glass-card rounded-[2rem] shadow-[0px_24px_48px_rgba(0,62,167,0.05)] p-8 md:p-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <%# ── Left column: rim details ──────────────────────────────── %>
        <section class="bg-[#f2f4f6] rounded-2xl p-6 space-y-8">
          <header class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-2xl">settings</span>
            <h2 class="font-headline text-xl font-semibold tracking-tight text-on-surface">Ratlankio informacija</h2>
          </header>

          <div class="space-y-6">

            <%# Name — full width %>
            <div class="space-y-2">
              <%= form.label :name, t('.fields.name.label'),
                    class: "block font-label text-[10px] uppercase tracking-widest text-outline pl-1" %>
              <%= form.text_field :name,
                    autofocus: true,
                    class: "w-full !bg-[#e0e3e5] border-0 ring-0 shadow-none rounded-2xl px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:ring-offset-0 focus:border-0 transition-all outline-none text-on-surface placeholder:text-outline/50" %>
            </div>

            <%# Brand %>
            <div class="space-y-2">
              <%= form.label :brand, t('.fields.brand.label'),
                    class: "block font-label text-[10px] uppercase tracking-widest text-outline pl-1" %>
              <%= form.text_field :brand,
                    placeholder: "e.g. BBS, OZ Racing",
                    class: "w-full !bg-[#e0e3e5] border-0 ring-0 shadow-none rounded-2xl px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:ring-offset-0 focus:border-0 transition-all outline-none text-on-surface placeholder:text-outline/50" %>
            </div>

            <%# Diameter + Width side by side %>
            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-2">
                <%= form.label :diameter, t('.fields.diameter.label'),
                      class: "block font-label text-[10px] uppercase tracking-widest text-outline pl-1" %>
                <%= form.select :diameter,
                      (14..40).map { |d| ["#{d}\"", d] },
                      { include_blank: "—" },
                      class: "w-full !bg-[#e0e3e5] border-0 ring-0 shadow-none rounded-2xl px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:ring-offset-0 focus:border-0 transition-all outline-none text-on-surface" %>
              </div>
              <div class="space-y-2">
                <%= form.label :width, t('.fields.width.label'),
                      class: "block font-label text-[10px] uppercase tracking-widest text-outline pl-1" %>
                <%= form.select :width,
                      BigDecimal("3.0").step(BigDecimal("30.0"), BigDecimal("0.5")).map { |w| ["#{w}\"", w] },
                      { include_blank: "—" },
                      class: "w-full !bg-[#e0e3e5] border-0 ring-0 shadow-none rounded-2xl px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:ring-offset-0 focus:border-0 transition-all outline-none text-on-surface" %>
              </div>
            </div>

            <%# Finish %>
            <div class="space-y-2">
              <%= form.label :finish, t('.fields.finish.label'),
                    class: "block font-label text-[10px] uppercase tracking-widest text-outline pl-1" %>
              <%= form.text_field :finish,
                    placeholder: "e.g. Gloss Black, Brushed Silver",
                    class: "w-full !bg-[#e0e3e5] border-0 ring-0 shadow-none rounded-2xl px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:ring-offset-0 focus:border-0 transition-all outline-none text-on-surface placeholder:text-outline/50" %>
            </div>

          </div>
        </section>

        <%# ── Right column: photo ───────────────────────────────────── %>
        <% photo_attached = rim.persisted? && rim.photo.attached? %>
        <section class="bg-[#f2f4f6] rounded-2xl p-6 space-y-6 flex flex-col"
                 id="rim-photo-section">
          <%= render PhotoHintComponent.new(
            subdir: "rims",
            title: t(".photo_hint.title"),
            paragraphs: t(".photo_hint.paragraphs"),
            tiles: [
              { key: "good_straight",     status: :good, alt: t(".photo_hint.tiles.good_straight.alt") },
              { key: "good_slight_angle", status: :good, alt: t(".photo_hint.tiles.good_slight_angle.alt") },
              { key: "bad_mounted",       status: :bad,  alt: t(".photo_hint.tiles.bad_mounted.alt") }
            ]
          ) %>

          <header class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-2xl">photo_camera</span>
            <h2 class="font-headline text-xl font-semibold tracking-tight text-on-surface">Ratlankio nuotrauka</h2>
          </header>

          <%# Hidden file input — always present %>
          <%= form.file_field :photo, id: "rim_photo", accept: "image/*", class: "sr-only" %>

          <script>
            (function() {
              function setupPhotoPreview() {
                var input    = document.getElementById("rim_photo");
                var filled   = document.getElementById("rim-photo-filled");
                var dropzone = document.getElementById("rim-photo-dropzone");
                var preview  = document.getElementById("rim-photo-preview");
                var filename = document.getElementById("rim-photo-filename");
                if (!input || input._photoPreviewBound) return;
                input._photoPreviewBound = true;
                input.addEventListener("change", function() {
                  var file = input.files[0];
                  if (!file) return;
                  preview.src = URL.createObjectURL(file);
                  filename.textContent = file.name;
                  filled.classList.remove("hidden");
                  filled.classList.add("flex");
                  dropzone.classList.add("hidden");
                  dropzone.classList.remove("flex");
                });
              }
              document.addEventListener("turbo:load", setupPhotoPreview);
              document.addEventListener("DOMContentLoaded", setupPhotoPreview);
            })();
          </script>

          <%# ── Filled state ──────────────────────────────────────── %>
          <div id="rim-photo-filled"
               class="flex-grow flex-col gap-4 <%= photo_attached ? 'flex' : 'hidden' %>">
            <img id="rim-photo-preview"
                 src="<%= photo_attached ? rails_representation_url(rim.photo.variant(format: :jpeg)) : '' %>"
                 class="h-56 w-full object-cover rounded-2xl" />
            <p id="rim-photo-filename"
               class="font-label text-[11px] text-outline truncate"><%= photo_attached ? rim.photo.filename : '' %></p>
            <div class="flex gap-3">
              <label for="rim_photo"
                     class="cursor-pointer inline-flex items-center gap-1.5 bg-[#eceef0] hover:bg-[#e0e3e5] text-on-surface font-label text-xs font-medium px-4 py-2.5 rounded-xl transition-colors">
                <span class="material-symbols-outlined" style="font-size: 15px;">upload_file</span>
                Pakeisti failą
              </label>
              <label class="cursor-pointer inline-flex items-center gap-1.5 bg-[#eceef0] hover:bg-[#e0e3e5] text-on-surface font-label text-xs font-medium px-4 py-2.5 rounded-xl transition-colors has-[:checked]:bg-red-50 has-[:checked]:text-red-600">
                <%= form.check_box :photo_removal, { class: "sr-only" }, "1", "0" %>
                <span class="material-symbols-outlined" style="font-size: 15px;">delete</span>
                Pašalinti failą
              </label>
            </div>
          </div>

          <%# ── Empty state — full-area clickable dropzone ─────────── %>
          <label for="rim_photo"
                 id="rim-photo-dropzone"
                 class="flex-grow relative flex-col items-center justify-center border-2 border-dashed border-[#c3c6d7]/50 bg-[#eceef0] rounded-2xl min-h-[280px] cursor-pointer hover:bg-[#e6e8ea] transition-colors overflow-hidden group <%= photo_attached ? 'hidden' : 'flex' %>">

            <%# Centered upload prompt %>
            <div class="relative z-10 flex flex-col items-center text-center px-6 pointer-events-none">
              <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-300 mb-4">
                <span class="material-symbols-outlined text-primary text-3xl">cloud_upload</span>
              </div>
              <p class="font-body font-medium text-on-surface text-sm mb-1">Spauskite arba įkelkite nuotrauką</p>
              <p class="font-label text-[11px] text-outline">Rekomenduojama: PNG, JPG (Max 10MB)</p>
            </div>

            <%# Ghost silhouette %>
            <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none select-none">
              <span class="material-symbols-outlined" style="font-size: 240px;">settings</span>
            </div>

          </label>

        </section>
      </div>

      <%# ── Footer actions ─────────────────────────────────────────── %>
      <footer class="mt-12 pt-8 border-t border-outline-variant/30 flex items-center justify-between">
        <%= link_to t('global.buttons.cancel'), cancel_path,
              class: "font-label text-sm text-outline hover:text-on-surface transition-colors" %>

        <button type="submit" class="primary-gradient text-white px-10 py-4 rounded-2xl font-headline font-bold text-base shadow-lg shadow-primary/20 hover:shadow-xl active:scale-95 transition-all flex items-center gap-2 group cursor-pointer">
          <span><%= form.object.persisted? ? t('.buttons.update') : t('.buttons.create') %></span>
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" style="font-size: 20px;">arrow_forward</span>
        </button>
      </footer>

    </div>
  <% end %>
<% end %>
