<%= render 'account/shared/page' do |page| %>
  <% page.title t('.section') %>
  <% page.body do %>
    <%= turbo_frame_tag "modal" do %>
    <%= cable_ready_updates_for @rim do %>
      <%= render RecordDetailComponent.new(
        title: @rim.display_name,
        image: @rim.photo.attached? ? rails_representation_url(@rim.photo.variant(format: :jpeg)) : nil,
        identifier: "ID-#{@rim.id}",
        status: t('.header'),
        stats: [
          { label: t('.fields.created_at.heading'), value: l(@rim.created_at.to_date, format: :long) }
        ],
        edit_path: can?(:edit, @rim) ? [:edit, :account, @rim] : nil,
        delete_path: can?(:destroy, @rim) ? [:account, @rim] : nil,
        delete_confirm: t('.buttons.confirmations.destroy', model_locales(@rim))
      ) %>
      <%# 🚅 super scaffolding will insert new children above this line. %>
    <% end %>
    <% end %>
  <% end %>
<% end %>
