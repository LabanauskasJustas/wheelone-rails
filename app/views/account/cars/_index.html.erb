<% cars = cars.accessible_by(current_ability) %>
<% team = @team %>
<% context ||= team %>
<% collection ||= :cars %>
<% hide_actions ||= false %>
<% hide_back ||= false %>

<% pagy ||= nil %>
<% pagy, cars = pagy(cars, page_param: :cars_page) unless pagy %>

<%= action_model_select_controller do %>
  <% cable_ready_updates_for context, collection do %>
    <%= render 'account/shared/box', pagy: pagy do |box| %>
      <% box.title t(".contexts.#{context.class.name.underscore}.header") %>
      <% box.description do %>
        <%= t(".contexts.#{context.class.name.underscore}.description#{"_empty" unless cars.any?}") %>
        <%= render "shared/limits/index", model: cars.model %>
      <% end %>

      <% box.table do %>
        <% if cars.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 p-4">
            <% cars.each do |car| %>
              <%= render RecordCardComponent.new(
                record: car,
                show_path: [:account, car],
                edit_path: can?(:edit, car) ? [:edit, :account, car] : nil,
                image: car.photo.attached? ? rails_blob_url(car.photo) : nil,
                title: car.display_name
              ) %>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <% box.actions do %>
        <% unless hide_actions %>
          <% if context == team %>
            <% if can? :create, Car.new(team: team) %>
              <%= link_to t('.buttons.new'), [:new, :account, team, :car], class: "#{first_button_primary(:car)} new" %>
            <% end %>
          <% end %>

          <%# 🚅 super scaffolding will insert new targets one parent action model buttons above this line. %>
          <%# 🚅 super scaffolding will insert new bulk action model buttons above this line. %>

          <% unless hide_back %>
            <%= link_to t('global.buttons.back'), [:account, context], class: "#{first_button_primary(:car)} back" %>
          <% end %>
        <% end %>
      <% end %>

      <% box.raw_footer do %>
        <%# 🚅 super scaffolding will insert new action model index views above this line. %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
