<%= render 'account/shared/page' do |page| %>
  <% page.title t('.section') %>
  <% page.body do %>
    <%= turbo_frame_tag "modal" do %>
    <%= cable_ready_updates_for @car do %>
      <%= render RecordDetailComponent.new(
        title: @car.display_name,
        image: @car.photo.attached? ? rails_blob_url(@car.photo) : nil,
        identifier: "ID-#{@car.id}",
        status: t('.header'),
        stats: [
          { label: t('.fields.created_at.heading'), value: l(@car.created_at.to_date, format: :long) },
          { label: t('.fields.updated_at.heading'), value: l(@car.updated_at.to_date, format: :long) }
        ],
        edit_path: can?(:edit, @car) ? [:edit, :account, @car] : nil,
        delete_path: can?(:destroy, @car) ? [:account, @car] : nil,
        delete_confirm: t('.buttons.confirmations.destroy', model_locales(@car))
      ) %>
      <%# 🚅 super scaffolding will insert new children above this line. %>
    <% end %>
    <% end %>
  <% end %>
<% end %>
