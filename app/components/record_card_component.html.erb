<div class="group relative rounded-lg overflow-hidden shadow-[0px_8px_24px_rgba(0,62,167,0.08)] hover:shadow-[0px_16px_32px_rgba(0,62,167,0.14)] transition-shadow duration-300">

  <%# Hero image %>
  <div class="relative h-48 w-full overflow-hidden bg-base-200 dark:bg-base-700">
    <% if image.present? %>
      <%= image_tag image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: title %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center">
        <span class="material-symbols-outlined text-6xl text-base-400">photo_camera</span>
      </div>
    <% end %>

    <%# Bottom gradient fade %>
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent pointer-events-none"></div>

    <%# Pill badge — top right %>
    <% if badge.present? %>
      <div class="absolute top-4 right-4">
        <span class="bg-white/80 dark:bg-base-800/80 backdrop-blur-md px-3 py-1 rounded-full font-label text-[10px] font-bold tracking-[0.05em] text-primary-600 dark:text-primary-400 shadow-sm uppercase">
          <%= badge %>
        </span>
      </div>
    <% end %>
  </div>

  <%# Glass card body pulling up over the image %>
  <div class="relative px-5 pb-5 -mt-8 z-10">
    <div class="glass-card rounded-lg px-5 py-4 shadow-md">

      <%# Title %>
      <h3 class="font-headline font-[700] text-base tracking-tight text-md-on-surface uppercase truncate mb-1">
        <% if show_path.present? %>
          <%= link_to title, show_path, data: { turbo_frame: "modal" }, class: "hover:text-primary-600 transition-colors after:absolute after:inset-0 after:z-0" %>
        <% else %>
          <%= title %>
        <% end %>
      </h3>

      <% if subtitle.present? %>
        <p class="font-label text-xs text-md-on-surface-variant truncate mb-3"><%= subtitle %></p>
      <% end %>

      <% if edit_path.present? %>
        <div class="flex justify-end mt-2 relative z-10">
          <%= link_to edit_path, class: "inline-flex items-center gap-1 text-xs font-semibold text-primary-600 dark:text-primary-400 hover:underline" do %>
            <span class="material-symbols-outlined" style="font-size: 14px;">edit</span>
            <%= t("global.buttons.edit") %>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>

</div>
